  object ped_ven_ite: TIBQuery
    Tag = 1
    Database = FBird.DBERP
    Transaction = IBTra
    SQL.Strings = (
      'SELECT   PK.ID,PK.IDEP,'
      '         PK.IDPK,PK.ID AS IDFK,PK.ITEM,'
      '         PK.IDCP,PK.CP_IDEP,'
      '         CP.ARTIGO,CP.SKU,PK.CEAN,PK.DECP,PK.DGCP,'
      '         PK.UCOM,PK.UCON,CP.UPSBR,CP.UPSLQ,'
      '         PK.QTDE,PK.QTRL,PK.PSBR,PK.PSLQ,'
      '         PK.VPRC_PAD_INI,PK.VPRC_PAD_FIM,'
      '         PK.VPRC_PAD,PK.VPRC_COM,'
      '         PK.PDSC,PK.VDSC,'
      '         PK.TSDE,PK.TCDE,'
      '         PK.ORIG,PK.NCM ,PK.PIPI,PK.VIPI,'
      '         PK.IDSP'
      'FROM     PED_VEN_ITE AS PK'
      'JOIN     CAD_PRO     AS CP ON (CP.ID = PK.IDCP)'
      'WHERE    PK.IDPK = 0'
      'ORDER BY PK.VPRC_COM DESC')
    Left = 440
    Top = 496
    object ped_ven_iteID: TIntegerField
